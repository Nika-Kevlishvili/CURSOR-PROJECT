#!/bin/sh
# Reject commits that track Chat report content or weaken .gitignore for Chat reports.
# Policy: under reports/Chat reports/ only .gitkeep may be committed.

set -e

REPO_ROOT=$(git rev-parse --show-toplevel)
cd "$REPO_ROOT"

# 1) No non-.gitkeep files under Chat reports (exclude pure deletions — removing bad paths is allowed)
STAGED_NON_DELETE=$(git diff --cached --name-only --diff-filter=d)

BAD_CHAT=$(printf '%s\n' "$STAGED_NON_DELETE" | grep -E 'reports/Chat reports/' | grep -Ev '\.gitkeep$' || true)
if [ -n "$BAD_CHAT" ]; then
  printf '%s\n' "ERROR: commits under reports/Chat reports/ are not allowed (except .gitkeep)." >&2
  printf '%s\n' "Staged paths:" >&2
  printf '%s\n' "$BAD_CHAT" >&2
  exit 1
fi

# 2) Do not re-introduce a negation that tracks *.md under Chat reports in Cursor-Project/.gitignore
STAGED_ALL=$(git diff --cached --name-only)
if printf '%s\n' "$STAGED_ALL" | grep -qx 'Cursor-Project/.gitignore'; then
  if git diff --cached -- "Cursor-Project/.gitignore" | grep '^+' | grep -i 'chat reports' | grep -iE '\.md|\.MD'; then
    printf '%s\n' "ERROR: do not add .gitignore rules that track markdown (or similar) under reports/Chat reports/." >&2
    exit 1
  fi
fi

exit 0
