# Reports: Feedback + HandsOff — full tree tracked at any path/date.
# Chat reports — folder structure allowed; only .gitkeep tracked (all other files skipped).
reports/**
!reports/Feedback/
!reports/Feedback/**
!reports/HandsOff reports/
!reports/HandsOff reports/**
!reports/Chat reports/
reports/Chat reports/**
!reports/Chat reports/**/
!reports/Chat reports/**/.gitkeep
