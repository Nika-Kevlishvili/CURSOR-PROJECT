                         "body":  {
                                      "type":  "doc",
                                      "version":  1,
                                      "content":  [
                                                      {
                                                          "type":  "paragraph",
                                                          "content":  [
                                                                          {
                                                                              "type":  "mention",
                                                                              "attrs":  {
                                                                                            "id":  "636cce6a524352f9c6e4cce9",
                                                                                            "text":  "@Dobromir.Kostov",
                                                                                            "accessLevel":  ""
                                                                                        }
                                                                          },
                                                                          {
                                                                              "type":  "text",
                                                                              "text":  " "
                                                                          },
                                                                          {
                                                                              "type":  "hardBreak"
                                                                          },
                                                                          {
                                                                              "type":  "text",
                                                                              "text":  "Could you please specify the expected performance criteria for this object?"
                                                                          }
                                                                      ]
                                                      },
                                                      {
                                                          "type":  "paragraph",
                                                          "content":  [
                                                                          {
                                                                              "type":  "text",
                                                                              "text":  "In particular, what response times are considered acceptable for POD loading:"
                                                                          }
                                                                      ]
                                                      },
                                                      {
                                                          "type":  "bulletList",
                                                          "content":  [
                                                                          {
                                                                              "type":  "listItem",
                                                                              "content":  [
                                                                                              {
                                                                                                  "type":  "paragraph",
                                                                                                  "content":  [
                                                                                                                  {
                                                                                                                      "type":  "text",
                                                                                                                      "text":  "First page"
                                                                                                                  }
                                                                                                              ]
                                                                                              }
                                                                                          ]
                                                                          },
                                                                          {
                                                                              "type":  "listItem",
                                                                              "content":  [
                                                                                              {
                                                                                                  "type":  "paragraph",
                                                                                                  "content":  [
                                                                                                                  {
                                                                                                                      "type":  "text",
                                                                                                                      "text":  "Last page (for example, when loading ~1500 PODs)"
                                                                                                                  }
                                                                                                              ]
                                                                                              }
                                                                                          ]
                                                                          }
                                                                      ]
                                                      },
                                                      {
                                                          "type":  "paragraph",
                                                          "content":  [
                                                                          {
                                                                              "type":  "text",
                                                                              "text":  "Also, what is the acceptable execution time for Request for Disconnection?"
                                                                          }
                                                                      ]
                                                      },
                                                      {
                                                          "type":  "paragraph",
                                                          "content":  [
                                                                          {
                                                                              "type":  "text",
                                                                              "text":  "Let’s use "
                                                                          },
                                                                          {
                                                                              "type":  "text",
                                                                              "text":  "1500 PODs",
                                                                              "marks":  [
                                                                                            {
                                                                                                "type":  "strong"
                                                                                            }
                                                                                        ]
                                                                          },
                                                                          {
                                                                              "type":  "text",
                                                                              "text":  " as the baseline scenario, based on the example you provided."
                                                                          }
                                                                      ]
                                                      }
                                                  ]
                                  },
