                                                                          }
                                                                      ]
                                                      },
                                                      {
                                                          "type":  "paragraph",
                                                          "content":  [
                                                                          {
                                                                              "type":  "text",
                                                                              "text":  "Hello,"
                                                                          }
                                                                      ]
                                                      },
                                                      {
                                                          "type":  "paragraph",
                                                          "content":  [
                                                                          {
                                                                              "type":  "text",
                                                                              "text":  "The buttons are being disabled due to a POD loading performance issue. They remain disabled until all existing PODs are loaded in this object, in order to prevent incorrect request submissions."
                                                                          }
                                                                      ]
                                                      },
                                                      {
                                                          "type":  "paragraph",
                                                          "content":  [
                                                                          {
                                                                              "type":  "text",
                                                                              "text":  "Improving the performance of the “Request for Disconnection” process should also resolve this issue. Once PODs are loaded faster, the buttons will become available more quickly as well."
                                                                          }
                                                                      ]
                                                      },
