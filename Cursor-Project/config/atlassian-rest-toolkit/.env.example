# ============================================================
# Atlassian REST Toolkit — Environment Configuration
# ============================================================
# Copy this file to .env in the same directory and fill in
# your real values. NEVER commit .env to version control.
# ============================================================

# --- Jira credentials (REQUIRED) ---
JIRA_EMAIL=your-email@company.com
JIRA_API_TOKEN=your-jira-api-token-here
JIRA_BASE_URL=https://your-site.atlassian.net

# --- Confluence credentials (OPTIONAL — falls back to JIRA_* above) ---
# Uncomment and set these only if your Confluence uses a
# different Atlassian site or different credentials than Jira.
#
# CONFLUENCE_EMAIL=your-email@company.com
# CONFLUENCE_API_TOKEN=your-confluence-api-token-here
# CONFLUENCE_WIKI_BASE=https://your-wiki-site.atlassian.net/wiki
# CONFLUENCE_URL=https://your-wiki-site.atlassian.net/wiki/home

# ============================================================
# HOW TO GET AN API TOKEN:
#   1. Go to https://id.atlassian.com/manage-profile/security/api-tokens
#   2. Click "Create API token"
#   3. Give it a label (e.g. "REST Toolkit")
#   4. Copy the token and paste it above
# ============================================================
