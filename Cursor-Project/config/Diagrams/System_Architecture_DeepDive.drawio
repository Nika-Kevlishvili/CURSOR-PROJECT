        <mxCell id="blocked" value="BLOCK WORKFLOW&lt;br&gt;Escalate to user with all&lt;br&gt;failing axes and reasons" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#333333;strokeColor=#000000;fontColor=#FFFFFF;fontSize=12;fontStyle=1;" vertex="1" parent="1">
