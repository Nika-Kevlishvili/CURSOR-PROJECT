        </mxCell>
        <mxCell id="v2" value="NOT A BUG" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="190" y="700" width="120" height="35" as="geometry"/>
        </mxCell>
        <mxCell id="v3" value="INCONCLUSIVE" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=11;" vertex="1" parent="1">
