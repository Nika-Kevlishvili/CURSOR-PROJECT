          <mxGeometry x="530" y="255" width="240" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="tc_fe" value="test_cases/Frontend/&amp;lt;Topic&amp;gt;.md&lt;br&gt;(TC-FE-N only)" style="shape=document;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=0.15;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=11;" vertex="1" parent="1">
