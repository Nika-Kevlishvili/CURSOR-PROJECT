          <mxGeometry x="840" y="390" width="600" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="cs1" value="Rules: .cursor/rules/**/*.mdc (always injected by Cursor)&lt;br&gt;Agents: .cursor/agents/*.md (Task tool subagent specs)&lt;br&gt;Skills: .cursor/skills/*/SKILL.md (step-by-step procedure)&lt;br&gt;Commands: .cursor/commands/*.md (operational checklists)&lt;br&gt;Hooks: .cursor/hooks.json + .cursor/hooks/*.ps1 (enforcement)&lt;br&gt;&lt;br&gt;Rule → canon map: Cursor-Project/docs/RULES_CANONICAL_INDEX.md&lt;br&gt;Agent roster: Cursor-Project/docs/AGENT_SUBAGENT_MAP.md&lt;br&gt;Architecture: Cursor-Project/docs/WORKSPACE_PATTERNS.md" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#333333;fontSize=12;align=left;spacingLeft=10;" vertex="1" parent="1">
