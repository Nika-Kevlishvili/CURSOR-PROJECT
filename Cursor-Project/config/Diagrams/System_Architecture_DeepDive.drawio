        </mxCell>
        <mxCell id="v4" value="CANNOT REPRODUCE" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="460" y="700" width="160" height="35" as="geometry"/>
        </mxCell>
        <mxCell id="v5" value="PROCESS BLOCKED" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#333333;strokeColor=#000000;fontColor=#FFFFFF;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="630" y="700" width="150" height="35" as="geometry"/>
        </mxCell>

        <!-- Output: Slack + chat -->
        <mxCell id="out_chat" value="Full analysis → Chat" style="shape=document;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=0.15;fillColor=#FFFFFF;strokeColor=#333333;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="40" y="760" width="200" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="out_slack" value="Slack → #bug-validation&lt;br&gt;(C0AUEEDVCEL)" style="ellipse;shape=cloud;whiteSpace=wrap;html=1;fillColor=#E1D5E7;strokeColor=#9673A6;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="280" y="755" width="200" height="65" as="geometry"/>
        </mxCell>
        <mxCell id="out_disk" value="Disk: BugValidation_*.md&lt;br&gt;ONLY on /report or explicit save" style="shape=document;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=0.15;fillColor=#F5F5F5;strokeColor=#999999;fontSize=11;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="520" y="760" width="250" height="50" as="geometry"/>
        </mxCell>

        <!-- Error path: PROCESS BLOCKED -->
        <mxCell id="err_title" value="&lt;b&gt;Error / Failure Paths&lt;/b&gt;" style="text;html=1;align=left;fontSize=14;fontColor=#FF0000;" vertex="1" parent="1">
          <mxGeometry x="900" y="90" width="250" height="25" as="geometry"/>
        </mxCell>
        <mxCell id="err1" value="Jira MCP fails → REST fallback (Rule 42)&lt;br&gt;REST fails → PROCESS BLOCKED" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8CECC;strokeColor=#FF0000;fontSize=11;dashed=1;" vertex="1" parent="1">
