  <diagram id="p4-bug" name="4. Bug Validation (Rule 32)">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1920" pageHeight="1200" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <mxCell id="t1" value="&lt;b&gt;Bug Validation Workflow (Rule 32) — bug-validator / BugFinderAgent&lt;/b&gt;" style="text;html=1;align=center;fontSize=22;fontColor=#B85450;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="1840" height="35" as="geometry"/>
        </mxCell>
        <mxCell id="t1sub" value="READ-ONLY: no code edits, no test generation, no Playwright authoring during validation" style="text;html=1;align=center;fontSize=12;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="40" y="55" width="1840" height="20" as="geometry"/>
        </mxCell>

        <!-- Step 0 -->
        <mxCell id="s0" value="Step 0: Environment resolution&lt;br&gt;environment-resolver → switch-phoenix-branches.ps1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="40" y="90" width="360" height="50" as="geometry"/>
        </mxCell>

        <!-- Step 1: Jira ticket -->
        <mxCell id="s1" value="Step 1: Fetch Jira ticket&lt;br&gt;MCP → REST fallback (Rule 42)&lt;br&gt;+ linked Confluence (Rule 44)&lt;br&gt;+ attachments analysis" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="40" y="160" width="360" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="jira_cloud" value="Jira" style="ellipse;shape=cloud;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="450" y="160" width="120" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="e_s1_jira" style="endArrow=block;html=1;strokeColor=#6C8EBF;dashed=1;" edge="1" parent="1" source="s1" target="jira_cloud">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Step 1b: Diagrams -->
        <mxCell id="s1b" value="Step 1b: Check diagrams&lt;br&gt;Ticket attachments → config/Diagrams/&lt;br&gt;(Bundle 4/5/6 .svg fallback)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#333333;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="40" y="250" width="360" height="55" as="geometry"/>
        </mxCell>

        <!-- Step 2: Confluence broad search -->
        <mxCell id="s2" value="Step 2: Confluence BROAD search&lt;br&gt;(ONLY bug-validator may do this)&lt;br&gt;MCP → REST fallback (Rule 43)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8CECC;strokeColor=#B85450;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="40" y="325" width="360" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="conf_cloud" value="Confluence" style="ellipse;shape=cloud;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="450" y="325" width="140" height="65" as="geometry"/>
        </mxCell>
        <mxCell id="e_s2_conf" style="endArrow=block;html=1;strokeColor=#6C8EBF;dashed=1;" edge="1" parent="1" source="s2" target="conf_cloud">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="s2c" value="Phase 2 exclusion: for Prod/PreProd,&lt;br&gt;exclude Phase 2 / experimental wiki trees" style="text;html=1;align=left;fontSize=10;fontColor=#B85450;" vertex="1" parent="1">
          <mxGeometry x="600" y="340" width="280" height="30" as="geometry"/>
        </mxCell>

        <!-- Step 3: Swagger refresh (mandatory) -->
        <mxCell id="s3" value="Step 3: Swagger refresh (MANDATORY)&lt;br&gt;update-swagger-specs.ps1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="405" width="360" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="s3_fail" value="Swagger fail?&lt;br&gt;Continue with cached specs" style="text;html=1;align=left;fontSize=10;fontColor=#666666;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="420" y="415" width="220" height="25" as="geometry"/>
        </mxCell>

        <!-- Step 4: Phoenix code analysis -->
