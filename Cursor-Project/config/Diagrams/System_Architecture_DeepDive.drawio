          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e_blocked" value="Yes" style="endArrow=block;html=1;strokeColor=#FF0000;strokeWidth=2;" edge="1" parent="1" source="d_iter" target="blocked">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Pass path -->
        <mxCell id="done" value="TCs saved and validated — workflow complete" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="110" y="610" width="350" height="45" as="geometry"/>
        </mxCell>
        <mxCell id="e_pass" value="≥ 80 ✓" style="endArrow=block;html=1;strokeColor=#82B366;strokeWidth=2;" edge="1" parent="1" source="d_pass" target="done">
          <mxGeometry relative="1" as="geometry"/>
