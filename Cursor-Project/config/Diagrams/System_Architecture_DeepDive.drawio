        <!-- Step 0: Env resolve -->
        <mxCell id="s0" value="Env resolve (PHOENIX-SWITCH.0)&lt;br&gt;switch-phoenix-branches.ps1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=12;" vertex="1" parent="1">
