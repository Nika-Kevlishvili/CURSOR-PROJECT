# Git Submodules Template
# Copy this file to your project root as `.gitmodules` and replace placeholder URLs
# with your actual GitLab/GitHub repository URLs.
#
# Usage:
#   1. Copy this file:  Copy-Item .gitmodules.example ..\.gitmodules
#   2. Edit URLs below to match your repos
#   3. Run:  git submodule init && git submodule update
#
# Structure:
#   project-root/
#   ├── .gitmodules           (this file, at project root)
#   ├── Backend/              (your backend repos as submodules)
#   │   ├── service-core/
#   │   ├── service-api/
#   │   └── ...
#   ├── Frontend/             (your frontend repos as submodules)
#   │   └── webapp/
#   └── TestAutomation/       (your test automation repo)
#       └── e2e-tests/

# ─── Backend repositories ───────────────────────────────────────────

[submodule "Backend/service-core"]
	path = Backend/service-core
	url = https://gitlab.your-company.com/your-project/service-core.git

[submodule "Backend/service-api"]
	path = Backend/service-api
	url = https://gitlab.your-company.com/your-project/service-api.git

[submodule "Backend/service-scheduler"]
	path = Backend/service-scheduler
	url = https://gitlab.your-company.com/your-project/service-scheduler.git

# ─── Frontend repositories ──────────────────────────────────────────

[submodule "Frontend/webapp"]
	path = Frontend/webapp
	url = https://gitlab.your-company.com/your-project/webapp.git

# ─── Test automation ────────────────────────────────────────────────

[submodule "TestAutomation/e2e-tests"]
	path = TestAutomation/e2e-tests
	url = https://github.com/your-org/e2e-tests.git

# ─── Add more submodules as needed ──────────────────────────────────
# [submodule "Backend/another-service"]
# 	path = Backend/another-service
# 	url = https://gitlab.your-company.com/your-project/another-service.git
